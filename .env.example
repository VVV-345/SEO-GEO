# OpenAI 兼容接口配置（适配 DeepSeek / 智谱 / 通义 / Moonshot / OpenAI 等）
# 任选其一，填入对应的 base_url / api_key / model。
#
# DeepSeek:   LLM_BASE_URL=https://api.deepseek.com                       LLM_MODEL=deepseek-chat
# 智谱 GLM:   LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4           LLM_MODEL=glm-4-plus
# 通义千问:    LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  LLM_MODEL=qwen-plus
# Moonshot:   LLM_BASE_URL=https://api.moonshot.cn/v1                      LLM_MODEL=moonshot-v1-8k
# OpenAI:     LLM_BASE_URL=https://api.openai.com/v1                      LLM_MODEL=gpt-4o-mini
#
# 要求：提供商需支持 JSON 模式（response_format=json_object）。

LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# 可选：SERP + 竞品分析 Agent 独立模型。留空时复用上面的 LLM_*。
COMPETITOR_LLM_BASE_URL=
COMPETITOR_LLM_API_KEY=
COMPETITOR_LLM_MODEL=

# 可选：技术 SEO 审计 Agent 独立模型。留空时复用 LLM_*。
TECHNICAL_SEO_LLM_BASE_URL=
TECHNICAL_SEO_LLM_API_KEY=
TECHNICAL_SEO_LLM_MODEL=
